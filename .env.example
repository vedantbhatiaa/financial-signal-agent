# Copy this file to .env and fill in your keys
# NEVER commit .env to Git — it is listed in .gitignore

# LLM provider — only one is needed
GROQ_API_KEY=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

# News data — optional, RSS feeds work without this
NEWS_API_KEY=your_newsapi_key_here

# PostgreSQL — these match the defaults in docker-compose.yml
POSTGRES_USER=user
POSTGRES_PASSWORD=pass
POSTGRES_DB=findb
POSTGRES_URI=postgresql://user:pass@127.0.0.1:5433/findb

# MongoDB — default Docker setup needs no auth
MONGO_URI=mongodb://localhost:27017
